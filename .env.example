# Environment Variables Template (copy to .env)

# Cassandra
CASSANDRA_HOST=localhost
CASSANDRA_KEYSPACE=geoloc

# Redis (for future use)
REDIS_HOST=localhost
REDIS_PORT=6379

# Server
PORT=8080

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000
# OAuth & Sessions (REQUIRED for OAuth functionality)
SESSION_SECRET=generate-a-random-string-with-openssl-rand-base64-32

# OAuth Providers (Google)
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

# OAuth Providers (Apple)
# APPLE_CLIENT_ID=your-client-id
# APPLE_CLIENT_SECRET=your-client-secret
# APPLE_CALLBACK_URL=http://localhost:8080/auth/apple/callback

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here

# Base URL
BASE_URL=http://localhost:8080

# Cloudflare R2 (media storage — required for uploads in production)
# API responses return presigned GET URLs; clients fetch media directly from R2.
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=geoloc-media